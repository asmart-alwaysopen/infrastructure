pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  parameters {
    choice(name: 'ACTION', choices: ['plan', 'apply', 'destroy'], description: 'Validate, deploy, or destroy support infrastructure.')
    choice(name: 'ENVIRONMENT', choices: ['dev', 'staging', 'production'], description: 'Environment identifier used for safety checks.')
    string(name: 'AWS_REGION', defaultValue: 'us-east-1', description: 'AWS region for the EKS cluster.')
    string(name: 'CLUSTER_NAME', defaultValue: 'always-open-eks', description: 'Target EKS cluster name.')
    string(name: 'AWS_CREDENTIALS_ID', defaultValue: 'aws-jenkins', description: 'Jenkins AWS credentials ID.')
    string(name: 'NAMESPACE_INFRA', defaultValue: 'always-open-infra', description: 'Namespace for shared infra dependencies (mongodb/rabbitmq/qdrant).')
    string(name: 'NAMESPACE_APP', defaultValue: 'always-open', description: 'Namespace for app mesh config and app-facing Istio resources.')
    string(name: 'NAMESPACE_ISTIO', defaultValue: 'istio-system', description: 'Namespace for Istio control plane and ingress.')
    string(name: 'ISTIO_VERSION', defaultValue: '1.20.0', description: 'Istio Helm chart version.')
    string(name: 'DOMAIN_NAME', defaultValue: 'bealwaysopen.com', description: 'Domain used by always-open-istio chart.')
    string(name: 'HELM_WAIT_TIMEOUT', defaultValue: '20m', description: 'Helm --wait timeout (e.g. 15m, 20m). MongoDB StatefulSet first boot often needs >5m.')
    booleanParam(name: 'REQUIRE_MANUAL_APPROVAL', defaultValue: false, description: 'When true, require approval before apply/destroy.')
  }

  environment {
    SUPPORT_DIR = 'infrastructure/support'
    CHARTS_DIR  = 'infrastructure/support/charts'
    MANIFESTS_DIR = 'infrastructure/support/manifests/istio'
    HELM_WAIT_TIMEOUT = "${params.HELM_WAIT_TIMEOUT}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Resolve Paths') {
      steps {
        script {
          if (fileExists('infrastructure/support/charts/mongodb/Chart.yaml')) {
            env.SUPPORT_DIR = 'infrastructure/support'
          } else if (fileExists('support/charts/mongodb/Chart.yaml')) {
            env.SUPPORT_DIR = 'support'
          } else {
            error('Could not find support charts. Expected infrastructure/support/charts/mongodb/Chart.yaml or support/charts/mongodb/Chart.yaml in workspace.')
          }
          env.CHARTS_DIR = "${env.SUPPORT_DIR}/charts"
          env.MANIFESTS_DIR = "${env.SUPPORT_DIR}/manifests/istio"
          echo "Using support directory: ${env.SUPPORT_DIR}"
        }
      }
    }

    stage('Safety Check') {
      when {
        expression { params.ACTION == 'destroy' }
      }
      steps {
        script {
          if (params.ENVIRONMENT == 'production' || params.ENVIRONMENT == 'prod') {
            error("Destroy is blocked for production environments. ENVIRONMENT='${params.ENVIRONMENT}'.")
          }
        }
      }
    }

    stage('Configure Cluster Access') {
      steps {
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: params.AWS_CREDENTIALS_ID,
          accessKeyVariable: 'AWS_ACCESS_KEY_ID',
          secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
        ]]) {
          sh '''
            set -euo pipefail
            : "${CHARTS_DIR:=infrastructure/support/charts}"
            : "${MANIFESTS_DIR:=infrastructure/support/manifests/istio}"
            aws eks update-kubeconfig --region "${AWS_REGION}" --name "${CLUSTER_NAME}"
            kubectl cluster-info
          '''
        }
      }
    }

    stage('Prepare Helm Repos') {
      steps {
        sh '''
          set -euo pipefail
          helm repo add istio https://istio-release.storage.googleapis.com/charts >/dev/null 2>&1 || true
          helm repo update
        '''
      }
    }

    stage('Plan (Validation)') {
      when {
        expression { params.ACTION == 'plan' }
      }
      steps {
        sh '''
          set -euo pipefail
          : "${CHARTS_DIR:=infrastructure/support/charts}"
          : "${MANIFESTS_DIR:=infrastructure/support/manifests/istio}"

          if [ ! -d "${CHARTS_DIR}" ]; then
            if [ -d "support/charts" ]; then
              CHARTS_DIR="support/charts"
              MANIFESTS_DIR="support/manifests/istio"
            else
              echo "Support charts directory not found: ${CHARTS_DIR}" >&2
              exit 1
            fi
          fi

          # Leaf charts (no Chart.yaml "dependencies:") must not keep charts/*.tgz or
          # Chart.lock from an old subchart wrap — helm lint then errors with
          # "chart metadata is missing these dependencies: <name>".
          prune_leaf_helm_chart() {
            local chart_dir="$1"
            local cf="${chart_dir}/Chart.yaml"
            [ -f "${cf}" ] || return 0
            if ! grep -qE '^[[:space:]]*dependencies:' "${cf}"; then
              rm -rf "${chart_dir}/charts" "${chart_dir}/Chart.lock"
            fi
          }
          prune_leaf_helm_chart "${CHARTS_DIR}/mongodb"
          prune_leaf_helm_chart "${CHARTS_DIR}/rabbitmq"
          prune_leaf_helm_chart "${CHARTS_DIR}/qdrant"
          prune_leaf_helm_chart "${CHARTS_DIR}/always-open-istio"

          helm dependency build "${CHARTS_DIR}/mongodb"
          helm dependency build "${CHARTS_DIR}/rabbitmq"
          helm dependency build "${CHARTS_DIR}/qdrant"

          helm lint "${CHARTS_DIR}/mongodb" --values "${CHARTS_DIR}/mongodb/values.yaml"
          helm lint "${CHARTS_DIR}/rabbitmq" --values "${CHARTS_DIR}/rabbitmq/values.yaml"
          helm lint "${CHARTS_DIR}/qdrant" --values "${CHARTS_DIR}/qdrant/values.yaml"
          helm lint "${CHARTS_DIR}/always-open-istio" --values "${CHARTS_DIR}/always-open-istio/values.yaml"

          helm template mongodb "${CHARTS_DIR}/mongodb" \
            --namespace "${NAMESPACE_INFRA}" \
            --values "${CHARTS_DIR}/mongodb/values.yaml" >/dev/null

          helm template rabbitmq "${CHARTS_DIR}/rabbitmq" \
            --namespace "${NAMESPACE_INFRA}" \
            --values "${CHARTS_DIR}/rabbitmq/values.yaml" >/dev/null

          helm template qdrant "${CHARTS_DIR}/qdrant" \
            --namespace "${NAMESPACE_INFRA}" \
            --values "${CHARTS_DIR}/qdrant/values.yaml" >/dev/null

          helm template always-open-istio "${CHARTS_DIR}/always-open-istio" \
            --namespace "${NAMESPACE_APP}" \
            --set "domain=${DOMAIN_NAME}" >/dev/null
        '''
      }
    }

    stage('Apply Support Infra') {
      when {
        expression { params.ACTION == 'apply' }
      }
      steps {
        script {
          if (params.REQUIRE_MANUAL_APPROVAL) {
            input message: "Deploy support infrastructure to '${params.ENVIRONMENT}' (${params.CLUSTER_NAME})?"
          }
        }
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: params.AWS_CREDENTIALS_ID,
          accessKeyVariable: 'AWS_ACCESS_KEY_ID',
          secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
        ]]) {
          sh '''
            set -euo pipefail
            : "${CHARTS_DIR:=infrastructure/support/charts}"
            : "${MANIFESTS_DIR:=infrastructure/support/manifests/istio}"

            if [ ! -d "${CHARTS_DIR}" ]; then
              if [ -d "support/charts" ]; then
                CHARTS_DIR="support/charts"
                MANIFESTS_DIR="support/manifests/istio"
              else
                echo "Support charts directory not found: ${CHARTS_DIR}" >&2
                exit 1
              fi
            fi

            prune_leaf_helm_chart() {
              local chart_dir="$1"
              local cf="${chart_dir}/Chart.yaml"
              [ -f "${cf}" ] || return 0
              if ! grep -qE '^[[:space:]]*dependencies:' "${cf}"; then
                rm -rf "${chart_dir}/charts" "${chart_dir}/Chart.lock"
              fi
            }
            prune_leaf_helm_chart "${CHARTS_DIR}/mongodb"
            prune_leaf_helm_chart "${CHARTS_DIR}/rabbitmq"
            prune_leaf_helm_chart "${CHARTS_DIR}/qdrant"
            prune_leaf_helm_chart "${CHARTS_DIR}/always-open-istio"

            aws sts get-caller-identity >/dev/null

            kubectl create namespace "${NAMESPACE_INFRA}" --dry-run=client -o yaml | kubectl apply -f -
            kubectl create namespace "${NAMESPACE_APP}" --dry-run=client -o yaml | kubectl apply -f -
            kubectl create namespace "${NAMESPACE_ISTIO}" --dry-run=client -o yaml | kubectl apply -f -

            helm dependency build "${CHARTS_DIR}/mongodb"
            helm dependency build "${CHARTS_DIR}/rabbitmq"
            helm dependency build "${CHARTS_DIR}/qdrant"

            helm upgrade --install mongodb "${CHARTS_DIR}/mongodb" \
              --namespace "${NAMESPACE_INFRA}" \
              --values "${CHARTS_DIR}/mongodb/values.yaml" \
              --wait \
              --timeout "${HELM_WAIT_TIMEOUT}"

            helm upgrade --install rabbitmq "${CHARTS_DIR}/rabbitmq" \
              --namespace "${NAMESPACE_INFRA}" \
              --values "${CHARTS_DIR}/rabbitmq/values.yaml" \
              --wait \
              --timeout "${HELM_WAIT_TIMEOUT}"

            helm upgrade --install qdrant "${CHARTS_DIR}/qdrant" \
              --namespace "${NAMESPACE_INFRA}" \
              --values "${CHARTS_DIR}/qdrant/values.yaml" \
              --wait \
              --timeout "${HELM_WAIT_TIMEOUT}"

            # istiod (pilot-discovery) mutates istiod-default-validator webhooks (e.g. failurePolicy)
            # after install. Re-applying istio-base then hits Helm SSA conflicts unless we remove the
            # object so the chart can recreate it; istiod reconciles again on the next upgrade.
            kubectl delete validatingwebhookconfiguration istiod-default-validator --ignore-not-found=true

            helm upgrade --install istio-base istio/base \
              --namespace "${NAMESPACE_ISTIO}" \
              --version "${ISTIO_VERSION}" \
              --wait \
              --timeout "${HELM_WAIT_TIMEOUT}"

            helm upgrade --install istiod istio/istiod \
              --namespace "${NAMESPACE_ISTIO}" \
              --version "${ISTIO_VERSION}" \
              --set global.proxy.resources.requests.cpu=50m \
              --wait \
              --timeout "${HELM_WAIT_TIMEOUT}"

            helm upgrade --install istio-ingress istio/gateway \
              --namespace "${NAMESPACE_ISTIO}" \
              --version "${ISTIO_VERSION}" \
              --set service.type=LoadBalancer \
              --wait \
              --timeout "${HELM_WAIT_TIMEOUT}"

            kubectl label namespace "${NAMESPACE_APP}" istio-injection=enabled --overwrite

            helm upgrade --install always-open-istio "${CHARTS_DIR}/always-open-istio" \
              --namespace "${NAMESPACE_APP}" \
              --set "domain=${DOMAIN_NAME}" \
              --wait \
              --timeout "${HELM_WAIT_TIMEOUT}"

            if [ -d "${MANIFESTS_DIR}" ]; then
              kubectl apply -f "${MANIFESTS_DIR}/" || true
            fi

            kubectl wait --for=condition=available deployment/istiod -n "${NAMESPACE_ISTIO}" --timeout=300s
          '''
        }
      }
    }

    stage('Destroy Support Infra') {
      when {
        expression { params.ACTION == 'destroy' }
      }
      steps {
        script {
          if (params.REQUIRE_MANUAL_APPROVAL) {
            input message: "Destroy support infrastructure for '${params.ENVIRONMENT}' (${params.CLUSTER_NAME})?"
          }
        }
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: params.AWS_CREDENTIALS_ID,
          accessKeyVariable: 'AWS_ACCESS_KEY_ID',
          secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
        ]]) {
          sh '''
            set -euo pipefail
            : "${CHARTS_DIR:=infrastructure/support/charts}"
            : "${MANIFESTS_DIR:=infrastructure/support/manifests/istio}"

            aws sts get-caller-identity >/dev/null

            helm uninstall always-open-istio --namespace "${NAMESPACE_APP}" || true
            helm uninstall istio-ingress --namespace "${NAMESPACE_ISTIO}" || true
            helm uninstall istiod --namespace "${NAMESPACE_ISTIO}" || true
            helm uninstall istio-base --namespace "${NAMESPACE_ISTIO}" || true

            helm uninstall qdrant --namespace "${NAMESPACE_INFRA}" || true
            helm uninstall rabbitmq --namespace "${NAMESPACE_INFRA}" || true
            helm uninstall mongodb --namespace "${NAMESPACE_INFRA}" || true
          '''
        }
      }
    }
  }
}
